# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=stock_signals
POSTGRES_USER=ssp_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── Qdrant ─────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── LLM ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=10
OPENAI_API_KEY=                        # fallback, optional

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=                        # email digest, optional
NOTIFICATION_EMAIL_TO=

# ── Data Sources ───────────────────────────────────────────
# Zerodha Kite (optional — falls back to yfinance if absent)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

NEWS_API_KEY=                          # NewsAPI.org

# ── Platform Config ────────────────────────────────────────
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO
PIPELINE_RUN_TIME=15:45               # IST — 10 min after market close
SIGNAL_EXPIRY_TRADING_DAYS=1
MAX_LLM_OVERRIDE_RATE=0.30            # alert if LLM overrides > 30%
